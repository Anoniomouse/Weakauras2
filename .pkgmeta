package-as: WeakAuras

externals:
  WeakAuras/Libs/LibStub:
    url: https://github.com/WoWUIDev/Ace3.git
    path: LibStub
  WeakAuras/Libs/CallbackHandler-1.0:
    url: https://github.com/WoWUIDev/Ace3.git
    path: CallbackHandler-1.0
  WeakAuras/Libs/AceTimer-3.0:
    url: https://github.com/WoWUIDev/Ace3.git
    path: AceTimer-3.0
  WeakAuras/Libs/AceSerializer-3.0:
    url: https://github.com/WoWUIDev/Ace3.git
    path: AceSerializer-3.0
  WeakAuras/Libs/AceComm-3.0:
    url: https://github.com/WoWUIDev/Ace3.git
    path: AceComm-3.0
  WeakAuras/Libs/Chomp: https://github.com/wow-rp-addons/Chomp.git
  WeakAuras/Libs/LibSharedMedia-3.0: https://github.com/wowace-clone/LibSharedMedia-3.0.git
  WeakAuras/Libs/LibDataBroker-1.1: https://github.com/tekkub/libdatabroker-1-1
  WeakAuras/Libs/LibCompress: https://github.com/szoyj/LibCompress
  WeakAuras/Libs/LibDeflate: https://github.com/SafeteeWoW/LibDeflate
  WeakAuras/Libs/LibSpellRange-1.0: https://github.com/ascott18/LibSpellRange-1.0
  WeakAuras/Libs/LibRangeCheck-3.0: https://github.com/WeakAuras/LibRangeCheck-3.0/
  WeakAuras/Libs/LibCustomGlow-1.0: https://github.com/Stanzilla/LibCustomGlow
  WeakAuras/Libs/LibDBIcon-1.0:
    url: https://github.com/wowace-clone/LibDBIcon-1.0.git
    path: LibDBIcon-1.0
  WeakAuras/Libs/LibGetFrame-1.0: https://github.com/mrbuds/LibGetFrame
  WeakAuras/Libs/Archivist:
    url: https://github.com/emptyrivers/Archivist
    tag: v1.0.8
  WeakAuras/Libs/LibSerialize:
    url: https://github.com/rossnichols/LibSerialize
    tag: v1.0.0
  WeakAuras/Libs/LibSpecialization:
    url: https://github.com/BigWigsMods/LibSpecialization.git/LibSpecialization
  WeakAuras/Libs/TaintLess:
    url: https://www.townlong-yak.com/addons.git/taintless
    commit: default
  WeakAuras/Libs/LibDispel:
    url: https://github.com/tukui-org/LibDispel.git
    commit: main
  WeakAurasOptions/Libs/AceConfig-3.0:
    url: https://github.com/WoWUIDev/Ace3.git
    path: AceConfig-3.0
  WeakAurasOptions/Libs/AceGUI-3.0:
    url: https://github.com/WoWUIDev/Ace3.git
    path: AceGUI-3.0
  WeakAurasOptions/Libs/AceGUI-3.0-SharedMediaWidgets:
    url: https://github.com/wowace-clone/AceGUI-3.0-SharedMediaWidgets.git
    path: AceGUI-3.0-SharedMediaWidgets
  WeakAurasOptions/Libs/LibUIDropDownMenu:
    url: https://github.com/wowace-clone/LibUIDropDownMenu.git
    path: LibUIDropDownMenu
  WeakAurasOptions/Libs/LibAPIAutoComplete-1.0: https://github.com/WeakAuras/LibAPIAutoComplete-1.0/

enable-nolib-creation: no

manual-changelog:
  filename: CHANGELOG.md
  markup-type: markdown

ignore:
  - README.md
  - CONTRIBUTING.md
  - CODE_OF_CONDUCT.md
  - babelfish.lua
  - update_translations.sh
  - generate_changelog.sh
  - cspell.json
  - stylua.toml
  - exclude_libs.txt
  - fetch_libs.ps1
  - tests
  - WeakAuras/Libs/LibDeflate/docs
  - WeakAuras/Libs/LibDeflate/examples
  - WeakAuras/Libs/LibDeflate/*.md

plain-copy:
  - WeakAurasModelPaths/*.lua

move-folders:
  WeakAuras/WeakAuras: WeakAuras
  WeakAuras/WeakAurasOptions: WeakAurasOptions
  WeakAuras/WeakAurasModelPaths: WeakAurasModelPaths
  WeakAuras/WeakAurasTemplates: WeakAurasTemplates
  WeakAuras/WeakAurasArchive: WeakAurasArchive
  WeakAuras/Libs/LibRangeCheck-3.0/LibRangeCheck-3.0: WeakAuras/Libs/LibRangeCheck-3.0
  WeakAurasOptions/Libs/LibAPIAutoComplete-1.0/LibAPIAutoComplete-1.0: WeakAurasOptions/Libs/LibAPIAutoComplete-1.0
